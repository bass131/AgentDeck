{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/agentdeck-hook.mjs\" prompt 42b91351622cb7fbfea8449947a9957a766ada41beef27894daa935f0dd06ea7",
            "commandWindows": "$root = git rev-parse --show-toplevel; node (Join-Path $root '.codex\\hooks\\agentdeck-hook.mjs') prompt 42b91351622cb7fbfea8449947a9957a766ada41beef27894daa935f0dd06ea7; exit $LASTEXITCODE",
            "timeout": 10,
            "statusMessage": "Loading AgentDeck work pin"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/agentdeck-hook.mjs\" subagent-start 42b91351622cb7fbfea8449947a9957a766ada41beef27894daa935f0dd06ea7",
            "commandWindows": "$root = git rev-parse --show-toplevel; node (Join-Path $root '.codex\\hooks\\agentdeck-hook.mjs') subagent-start 42b91351622cb7fbfea8449947a9957a766ada41beef27894daa935f0dd06ea7; exit $LASTEXITCODE",
            "timeout": 10,
            "statusMessage": "Loading AgentDeck role contract"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/agentdeck-hook.mjs\" pre-tool 42b91351622cb7fbfea8449947a9957a766ada41beef27894daa935f0dd06ea7",
            "commandWindows": "$root = git rev-parse --show-toplevel; node (Join-Path $root '.codex\\hooks\\agentdeck-hook.mjs') pre-tool 42b91351622cb7fbfea8449947a9957a766ada41beef27894daa935f0dd06ea7; exit $LASTEXITCODE",
            "timeout": 15,
            "statusMessage": "Checking AgentDeck guardrails"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/agentdeck-hook.mjs\" post-tool 42b91351622cb7fbfea8449947a9957a766ada41beef27894daa935f0dd06ea7",
            "commandWindows": "$root = git rev-parse --show-toplevel; node (Join-Path $root '.codex\\hooks\\agentdeck-hook.mjs') post-tool 42b91351622cb7fbfea8449947a9957a766ada41beef27894daa935f0dd06ea7; exit $LASTEXITCODE",
            "timeout": 15,
            "statusMessage": "Checking AgentDeck post-change gates"
          }
        ]
      }
    ]
  }
}
