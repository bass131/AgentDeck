{
  "name": "agentdeck",
  "version": "0.1.0",
  "description": "Claude Code · Codex 듀얼 백엔드 데스크톱 IDE",
  "main": "./out/main/index.js",
  "author": "AgentDeck",
  "license": "MIT",
  "scripts": {
    "predev": "npm run rebuild:native",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "prestart": "npm run rebuild:native",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pretest": "npm run rebuild:node",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/run-e2e.cjs",
    "test:e2e:visual": "node scripts/run-e2e.cjs tests/e2e/visual-viewer.e2e.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "better-sqlite3": "^12.11.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.2",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.0",
    "jsdom": "^24.1.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^3.2.0"
  }
}
