{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/agentdeck-hook.mjs\" prompt b0fe85caa9a1acdb9ba5e61ae829c544b9d207ce9d3bdd7eabf04fd84adee17d",
            "commandWindows": "$root = git rev-parse --show-toplevel; node (Join-Path $root '.codex\\hooks\\agentdeck-hook.mjs') prompt b0fe85caa9a1acdb9ba5e61ae829c544b9d207ce9d3bdd7eabf04fd84adee17d; exit $LASTEXITCODE",
            "timeout": 10,
            "statusMessage": "Loading AgentDeck work pin"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/agentdeck-hook.mjs\" subagent-start b0fe85caa9a1acdb9ba5e61ae829c544b9d207ce9d3bdd7eabf04fd84adee17d",
            "commandWindows": "$root = git rev-parse --show-toplevel; node (Join-Path $root '.codex\\hooks\\agentdeck-hook.mjs') subagent-start b0fe85caa9a1acdb9ba5e61ae829c544b9d207ce9d3bdd7eabf04fd84adee17d; exit $LASTEXITCODE",
            "timeout": 10,
            "statusMessage": "Loading AgentDeck role contract"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/agentdeck-hook.mjs\" pre-tool b0fe85caa9a1acdb9ba5e61ae829c544b9d207ce9d3bdd7eabf04fd84adee17d",
            "commandWindows": "$root = git rev-parse --show-toplevel; node (Join-Path $root '.codex\\hooks\\agentdeck-hook.mjs') pre-tool b0fe85caa9a1acdb9ba5e61ae829c544b9d207ce9d3bdd7eabf04fd84adee17d; exit $LASTEXITCODE",
            "timeout": 15,
            "statusMessage": "Checking AgentDeck guardrails"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/agentdeck-hook.mjs\" post-tool b0fe85caa9a1acdb9ba5e61ae829c544b9d207ce9d3bdd7eabf04fd84adee17d",
            "commandWindows": "$root = git rev-parse --show-toplevel; node (Join-Path $root '.codex\\hooks\\agentdeck-hook.mjs') post-tool b0fe85caa9a1acdb9ba5e61ae829c544b9d207ce9d3bdd7eabf04fd84adee17d; exit $LASTEXITCODE",
            "timeout": 15,
            "statusMessage": "Checking AgentDeck post-change gates"
          }
        ]
      }
    ]
  }
}
