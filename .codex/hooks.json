{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/agentdeck-hook.mjs\" prompt",
            "commandWindows": "@for /f \"delims=\" %i in ('git rev-parse --show-toplevel') do @node \"%i\\.codex\\hooks\\agentdeck-hook.mjs\" prompt",
            "timeout": 10,
            "statusMessage": "Loading AgentDeck work pin"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/agentdeck-hook.mjs\" subagent-start",
            "commandWindows": "@for /f \"delims=\" %i in ('git rev-parse --show-toplevel') do @node \"%i\\.codex\\hooks\\agentdeck-hook.mjs\" subagent-start",
            "timeout": 10,
            "statusMessage": "Loading AgentDeck role contract"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/agentdeck-hook.mjs\" pre-tool",
            "commandWindows": "@for /f \"delims=\" %i in ('git rev-parse --show-toplevel') do @node \"%i\\.codex\\hooks\\agentdeck-hook.mjs\" pre-tool",
            "timeout": 15,
            "statusMessage": "Checking AgentDeck guardrails"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/agentdeck-hook.mjs\" post-tool",
            "commandWindows": "@for /f \"delims=\" %i in ('git rev-parse --show-toplevel') do @node \"%i\\.codex\\hooks\\agentdeck-hook.mjs\" post-tool",
            "timeout": 15,
            "statusMessage": "Checking AgentDeck post-change gates"
          }
        ]
      }
    ]
  }
}
