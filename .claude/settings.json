{
  "$comment": "AgentDeck 하네스 — Claude Code 프로젝트 설정. hooks = 9종(pin-injector[UserPromptSubmit]·supervisor-guard[Supervisor 전임 강제]·dangerous-cmd-guard·tdd-guard·risk-detector·circuit-breaker·reviewer-auto-trigger·phase-gate-validator·convention-size-guard, .claude/hooks/*). 비가역(push/PR/merge/배포/package 릴리스)은 ask 게이트 보존(CORE-06). 헌법(CLAUDE.md)·.claude 하네스·의미 정본(00.Documents/harness·adr·ADR.md)은 사용자 단독 통제(CORE-11) — 기술 봉인(Edit deny + supervisor-guard, ADR-037). docs 일반은 규범 게이트.",

  "permissions": {
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Bash(npm install*)",
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npx vitest*)",
      "Bash(npx playwright*)",
      "Bash(npx tsc*)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout -- *)",
      "Bash(git stash *)",
      "Bash(ls*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)"
    ],

    "ask": [
      "Bash(npm run package*)",
      "Bash(npm publish*)",
      "Bash(git push*)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh release*)"
    ],

    "deny": [
      "Bash(curl*)",
      "Bash(wget*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Edit(.claude/hooks/**)",
      "Edit(.claude/agents/**)",
      "Edit(.claude/policies/**)",
      "Edit(.claude/skills/**)",
      "Edit(.claude/commands/**)",
      "Edit(.claude/settings.json)",
      "Edit(CLAUDE.md)",
      "Edit(00.Documents/harness/**)",
      "Edit(00.Documents/adr/**)",
      "Edit(00.Documents/ADR.md)"
    ]
  },

  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pin-injector.sh\"" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/supervisor-guard.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/dangerous-cmd-guard.sh\"" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/supervisor-guard.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/tdd-guard.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/risk-detector.sh\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/circuit-breaker.sh\"" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/reviewer-auto-trigger.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/phase-gate-validator.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/convention-size-guard.sh\"" }
        ]
      }
    ]
  }
}
